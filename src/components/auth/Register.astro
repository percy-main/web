---
import { SimpleInput } from "../form/SimpleInput";
---

<section>
  <div class="mx-auto flex flex-col items-center px-6 lg:py-0">
    <div
      class="w-full rounded-lg bg-white shadow-sm sm:max-w-md md:mt-0 md:p-0 dark:border dark:border-gray-700 dark:bg-gray-800"
    >
      <div class="space-y-4 p-6 sm:p-8 md:space-y-6">
        <h1
          class="text-xl leading-tight font-bold tracking-tight text-gray-900 md:text-2xl dark:text-white"
        >
          Create an Account
        </h1>
        <p class="prose">
          Register to manage your membership, track payments, and access the
          members area.
        </p>

        <button
          type="button"
          id="google-signin"
          class="flex w-full items-center justify-center rounded-lg border border-gray-300 bg-white px-5 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-50"
        >
          <svg class="mr-2 h-5 w-5" viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"
              fill="#4285F4"></path>
            <path
              d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
              fill="#34A853"></path>
            <path
              d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
              fill="#FBBC05"></path>
            <path
              d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
              fill="#EA4335"></path>
          </svg>
          Sign up with Google
        </button>

        <div class="flex items-center">
          <div class="h-px flex-1 bg-gray-300 dark:bg-gray-600"></div>
          <span class="px-4 text-sm text-gray-500 dark:text-gray-400">or</span>
          <div class="h-px flex-1 bg-gray-300 dark:bg-gray-600"></div>
        </div>

        <form class="space-y-4 md:space-y-6" id="register-form">
          <SimpleInput
            id="name"
            type="text"
            label="Name"
            required
          />
          <SimpleInput
            id="email"
            type="email"
            label="Email"
            required
          />
          <SimpleInput
            id="password"
            type="password"
            label="Password"
            required
          />
          <div id="register-error" class="hidden rounded-lg bg-amber-50 border border-amber-200 p-4 text-sm text-amber-800">
            <p class="font-medium">An account with this email already exists.</p>
            <p class="mt-1">
              You can <a href="/auth/login" class="font-medium underline">sign in here</a>, or
              <a href="/auth/reset-password" class="font-medium underline">reset your password</a> if you've forgotten it.
            </p>
          </div>
          <div id="register-generic-error" class="hidden rounded-lg bg-red-50 border border-red-200 p-4 text-sm text-red-800">
            <p>Something went wrong. Please try again.</p>
          </div>
          <div class="flex items-start gap-2">
            <input
              type="checkbox"
              id="age-confirmed"
              name="age_confirmed"
              class="mt-1 h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500"
              required
            />
            <label for="age-confirmed" class="text-sm text-gray-700 dark:text-gray-300">
              I confirm I am aged 13 or over
            </label>
          </div>
          <div id="age-error" class="hidden rounded-lg bg-red-50 border border-red-200 p-4 text-sm text-red-800">
            <p>You must confirm you are aged 13 or over to create an account.</p>
          </div>
          <div class="flex items-center justify-between">
            <button
              type="submit"
              class="focus:ring-primary-300 dark:bg-primary-600 dark:hover:bg-primary-700 dark:focus:ring-primary-800 w-full rounded-lg bg-blue-500 px-5 py-2.5 text-center text-sm font-medium text-white hover:bg-blue-700 focus:ring-4 focus:outline-hidden"
              >Create Account</button
            >
          </div>
          <p class="text-sm font-light text-gray-500 dark:text-gray-400">
            Already have an account?{" "}
            <a
              href="/auth/login"
              class="text-primary-600 dark:text-primary-500 font-medium hover:underline"
            >
              Sign in
            </a>
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  import { authClient } from "@/lib/auth/client";

  // Pre-fill from query params (backwards-compatible with old join flow links)
  const params = new URLSearchParams(window.location.search);
  const nameParam = params.get("name");
  const emailParam = params.get("email");

  if (nameParam) {
    const nameInput = document.getElementById("name") as HTMLInputElement | null;
    if (nameInput) nameInput.value = nameParam;
  }
  if (emailParam) {
    const emailInput = document.getElementById("email") as HTMLInputElement | null;
    if (emailInput) emailInput.value = emailParam;
  }

  // Google sign-up
  document.getElementById("google-signin")?.addEventListener("click", () => {
    const ageErrorEl = document.getElementById("age-error")!;
    const ageConfirmed = (document.getElementById("age-confirmed") as HTMLInputElement)?.checked;
    if (!ageConfirmed) {
      ageErrorEl.classList.remove("hidden");
      return;
    }
    ageErrorEl.classList.add("hidden");
    void authClient.signIn.social({
      provider: "google",
      callbackURL: "/members",
    });
  });

  // Email/password sign-up
  const form = document.getElementById("register-form") as HTMLFormElement;
  form.addEventListener("submit", async (event) => {
    event.preventDefault();

    const errorEl = document.getElementById("register-error")!;
    const genericErrorEl = document.getElementById("register-generic-error")!;
    const ageErrorEl = document.getElementById("age-error")!;
    errorEl.classList.add("hidden");
    genericErrorEl.classList.add("hidden");
    ageErrorEl.classList.add("hidden");

    const data = new FormData(event.target as HTMLFormElement);

    const ageConfirmed = (document.getElementById("age-confirmed") as HTMLInputElement)?.checked;
    if (!ageConfirmed) {
      ageErrorEl.classList.remove("hidden");
      return;
    }

    const name = data.get("name")?.toString() ?? "";
    const email = data.get("email")?.toString() ?? "";
    const password = data.get("password")?.toString() ?? "";

    const tmp = await authClient.signUp.email({
      name,
      email,
      password,
      callbackURL: "/auth/email-confirmed/",
    });

    if (!tmp.error) {
      window.location.href = "/auth/registered";
    } else if (tmp.error.code === "USER_ALREADY_EXISTS_USE_ANOTHER_EMAIL") {
      errorEl.classList.remove("hidden");
    } else {
      genericErrorEl.classList.remove("hidden");
    }
  });
</script>
